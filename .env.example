PORT=3000
APNS_KEY_ID=YOUR_APNS_KEY_ID
APNS_TEAM_ID=YOUR_APPLE_TEAM_ID
APNS_KEY_PATH=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
APNS_TOPIC=com.nelsongx.apps.fju-aio.push-type.liveactivity
APNS_USE_SANDBOX=true
LOG_LEVEL=info
DATABASE_PATH=./data/apple-notification.sqlite
# Optional. When set, protected endpoints require Authorization: Bearer <APP_AUTH_TOKEN>
APP_AUTH_TOKEN=
SCHEDULER_POLL_MS=250
SCHEDULER_BATCH_SIZE=25
SCHEDULER_LOCK_SECONDS=60
